{
  "name": "@greenproof/membrane-sdk",
  "version": "0.1.0",
  "description": "The official TypeScript SDK for the GreenProof Universal Trust Protocol.",
  "author": "Symbeon Labs <contact@symbeon.io>",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --strict"
  },
  "keywords": [
    "greenproof",
    "rwa",
    "esg",
    "zk-snarks",
    "chainlink",
    "blockchain",
    "sustainability",
    "membrane"
  ],
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/symbeon-labs/membrane-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/symbeon-labs/membrane-sdk/issues"
  },
  "homepage": "https://github.com/symbeon-labs/membrane-sdk#readme",
  "publishConfig": {
    "access": "public"
  }
}
